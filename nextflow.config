manifest {
    name            = 'nf-xenium-seg-search'
    author          = 'Altos Labs'
    homePage        = 'https://github.com/altos-labs/nf-xenium-seg-search'
    description     = 'Parameter grid search and cross-method comparison for Xenium cell segmentation'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '0.1.0'
}

params {
    // ── Required ────────────────────────────────────────────────────────────
    input           = null   // path to samplesheet CSV
    outdir          = null   // output directory

    // ── Marker genes ─────────────────────────────────────────────────────────
    markers         = null   // path to markers.yaml (gene → cell-type mapping for MECR)

    // ── SEGGER ───────────────────────────────────────────────────────────────
    segger_model    = null   // path to pre-trained SEGGER model (required for Stage 1; if null, SEGGER skipped in Stage 1)

    // ── Crop settings ────────────────────────────────────────────────────────
    crop_size_um    = 500    // crop side length in microns
    n_crops         = 10     // number of density-stratified crops for Stage 1
    pixel_size_um   = 0.2125 // Xenium pixel size at Level 0 (µm/pixel)

    // ── Scoring weights (must sum to 1.0) ────────────────────────────────────
    mecr_weight     = 0.5
    recovery_weight = 0.3
    yield_weight    = 0.2

    // ── Skip / resume options ────────────────────────────────────────────────
    skip_stage1     = false  // skip param search entirely
    optimal_params  = null   // path to pre-computed optimal_params.json (implies skip_stage1)

    // ── Param grid definitions ───────────────────────────────────────────────
    param_grids     = "${projectDir}/conf/param_grids.yaml"

    // ── Output ───────────────────────────────────────────────────────────────
    publish_dir_mode = 'copy'
    tracedir         = "${params.outdir}/pipeline_info"
}

process {
    cpus   = { 4    * task.attempt }
    memory = { 16.GB * task.attempt }
    time   = { 4.h  * task.attempt }

    errorStrategy = { task.exitStatus in [140, 143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 2

    withLabel: 'process_low' {
        cpus   = 2
        memory = 12.GB
        time   = 2.h
    }
    withLabel: 'process_medium' {
        cpus   = 6
        memory = 56.GB
        time   = 8.h
    }
    withLabel: 'process_high' {
        cpus   = 16
        memory = 120.GB
        time   = 24.h
    }
    withLabel: 'process_gpu' {
        cpus   = 8
        memory = 60.GB
        time   = 12.h
        // GPU resources configured per-profile below
    }
}

profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        conda.enabled          = false
    }
    gpu {
        docker.runOptions      = '-u $(id -u):$(id -g) --gpus all'
        process {
            withLabel: 'process_gpu' {
                containerOptions = '--gpus all'
            }
        }
    }
    aws {
        process {
            executor = 'awsbatch'
        }
    }
    test {
        params.input         = "${projectDir}/assets/test/samplesheet.csv"
        params.outdir        = './test_results'
        params.markers       = "${projectDir}/assets/markers/lung_markers.yaml"
        params.n_crops       = 3    // fewer crops for fast CI test
        params.crop_size_um  = 300
    }
}

timeline {
    enabled = true
    file    = "${params.tracedir}/execution_timeline.html"
}
report {
    enabled = true
    file    = "${params.tracedir}/execution_report.html"
}
trace {
    enabled = true
    file    = "${params.tracedir}/execution_trace.txt"
}
